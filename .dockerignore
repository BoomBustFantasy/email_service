# Ignore build output
bin/
obj/

# Ignore user-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore logs
*.log

# Ignore IDE settings
.vscode/
.idea/

# Ignore test results
TestResults/

# Ignore other common files
*.swp
*.tmp

# Don't ignore solution and project files!
!email_service.sln

# NuGet auth config (auth is handled via BuildKit secret at build time)
nuget.config
