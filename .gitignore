# .gitignore for C# / .NET projects
# Build results
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db

# NuGet
*.nupkg
# NuGet Packages folder can be ignored if not using package restore
#packages/

# NuGet auth config (contains credentials — copy nuget.config.template and fill in your PAT)
nuget.config

# Logs
*.log

# Rider
.idea/
*.sln.iml

# Others
*.vspscc
*.vssscc
_ReSharper*/

# DotCover
*.dotCover

# Test results
TestResults/
